// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  password      String       
  netIncome     Float        @default(0) 
  
  // Relationen
  items         BucketItem[] @relation("CreatedItems")
  approvedItems BucketItem[] @relation("ApprovedItems")
  expenses      Expense[]    @relation("UserExpenses") // NEU: Für variable Ausgaben
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model BucketItem {
  id          String   @id @default(cuid())
  title       String
  price       Float
  
  // NEU: Modul 2 - Our Journeys 2.0
  savedAmount Float    @default(0)     // Sinking Fund: Wie viel wurde schon angespart?
  isSurprise  Boolean  @default(false) // Blind Proposal: Ist es eine Überraschung?
  isCompleted Boolean  @default(false) // Memory Archive: Ist der Traum erfüllt?
  
  // Wer hat es erstellt?
  creatorId   String
  creator     User     @relation("CreatedItems", fields: [creatorId], references: [id])
  
  // Hat der andere zugestimmt? (Daumen hoch System)
  approverId  String?
  approver    User?    @relation("ApprovedItems", fields: [approverId], references: [id])
  
  isPurchased Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FinancialObligation {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  type        String   // z.B. "SCHULDEN_RATE", "FIXKOSTEN", "GEMEINSAME_AUSGABE"
  isShared    Boolean  @default(true) // Tragen es beide oder nur einer?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// NEU: Modul 1 - Variable Ausgaben (Der Daily Sync)
model Expense {
  id          String   @id @default(cuid())
  title       String   // z.B. "Rewe", "Tanken"
  amount      Float
  date        DateTime @default(now())
  
  // Wer hat es bezahlt?
  userId      String
  user        User     @relation("UserExpenses", fields: [userId], references: [id])
}